{
  "version": 2,
  "outputDirectory": ".",
  "builds": [
    {
      "src": "api/profiles.js",
      "use": "@vercel/node"
    },
    {
      "src": "**/*.{html,css,js,png,svg,jpg,ico,webp,woff,woff2}",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/profiles(.*)", "dest": "/api/profiles.js" },
    { "src": "/api/health",       "dest": "/api/health.js"   },
    { "src": "/(.*)",             "dest": "/$1"              }
  ]
}
